addEventHandler("ekranıKapat", root,
function()
	dgsSetVisible(beklemeEkrani, false)
end)

addEventHandler("onDgsTextChange", root, 
function()
	if source == txtCORenk then
		local renk = dgsGetText(txtCORenk)
		if #renk == 7 then
			local r, g, b = getColorFromString(renk)
			if not (r == false) then
				setTimer(function()dgsLabelSetColor(takimBilgi1L, r, g, b)
				dgsLabelSetColor(takimBilgi2L, r, g, b)end, 50, 1)
				dgsLabelSetColor(teamnamelblO, r, g, b)
				dgsLabelSetColor(taglblO, r, g, b)
				dgsLabelSetColor(renkkodulbl, r, g, b)
				dgsSetProperty(cbDavetEngelle, "textColor", tocolor(r, g, b, 255))
			end
		else
			dgsLabelSetColor(teamnamelblO, 0, 0, 0)
			dgsLabelSetColor(taglblO, 0, 0, 0)
			dgsLabelSetColor(renkkodulbl, 0, 0, 0)
			dgsLabelSetColor(takimBilgi1L, 0, 0, 0)
			dgsLabelSetColor(takimBilgi2L, 0, 0, 0)
			dgsSetProperty(cbDavetEngelle, "textColor", tocolor(0, 0, 0, 255))
		end
	end
end)

function secilen(gridList)
	local row, col = dgsGridListGetSelectedItem(gridList) 
	if row ~= -1 and col ~= -1 then
		return dgsGridListGetItemData(gridList, row, 1)
	else
		return false
	end
end

function secilenTakim(arg1, arg2, arg3, arg4, arg5, arg6, arg7, arg8, arg9, arg10)
	local r, g, b = getColorFromString(arg4)
	if arg5 == "sampiyonluk" then
		dgsSetText(takimbilgisi1EB4, arg1)
		dgsSetText(takimbilgisi2EB4, arg2)
		dgsSetText(takimKurucuL, "Takımın Kurucusu: "..arg3)
		dgsSetText(takimKurulusL, "Takımın Kuruluş Tarihi: "..arg6)
		dgsSetText(birincilikL, "Takımın Lig Sonu 1'inciliği: "..arg7)
		dgsSetText(ikincilikL, "Takımın Lig Sonu 2'inciliği: "..arg8)
		dgsSetText(ucunculukL, "Takımın Lig Sonu 3'üncülüğü: "..arg9)
		dgsSetText(takimKurucuRL, arg10)
		dgsSetText(takimbilgisi1EB5, arg1)
		dgsSetText(takimbilgisi2EB5, arg2)
		dgsSetText(takimKurucuL2, "Takımın Kurucusu: "..arg3)
		dgsSetText(takimKurulusL2, "Takımın Kuruluş Tarihi: "..arg6)
		dgsSetText(birincilikL2, "Takımın Lig Sonu 1'inciliği: "..arg7)
		dgsSetText(ikincilikL2, "Takımın Lig Sonu 2'inciliği: "..arg8)
		dgsSetText(ucunculukL2, "Takımın Lig Sonu 3'üncülüğü: "..arg9)
		dgsSetText(takimKurucuRL2, arg10)
		return
	end
	if arg5 == "user" then
		dgsSetText(takimbilgisi1EB1, arg1)
		dgsSetText(takimbilgisi2EB1, arg2)
		dgsSetText(takimbilgisi1EB3, arg1)
		dgsSetText(takimbilgisi2EB3, arg2)
		dgsGridListClearRow(takimListesi)
		dgsGridListClearRow(takimListesi2)
	elseif arg5 == "yetkili" then
		dgsGridListClearRow(yetkiliTakimdakiler)
		dgsGridListClearRow(yetkiliTakimdakiler2)
		dgsGridListClearRow(klanRutbeler2)
	end
	for i, v in ipairs(arg6) do
		if v.rutbe1 then
			local row1 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row1, 1, v.rutbe1)
			local r, g, b = getColorFromString(v.rutbe1r)
			dgsGridListSetItemColor(klanRutbeler2, row1, 1, r, g, b)
		end
		if v.rutbe2 then
			local row2 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row2, 1, v.rutbe2)
			local r, g, b = getColorFromString(v.rutbe2r)
			dgsGridListSetItemColor(klanRutbeler2, row2, 1, r, g, b)
		end
		if v.rutbe3 then
			local row3 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row3, 1, v.rutbe3)
			local r, g, b = getColorFromString(v.rutbe3r)
			dgsGridListSetItemColor(klanRutbeler2, row3, 1, r, g, b)
		end
		if v.rutbe4 then
			local row4 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row4, 1, v.rutbe4)
			local r, g, b = getColorFromString(v.rutbe4r)
			dgsGridListSetItemColor(klanRutbeler2, row4, 1, r, g, b)
		end
		if v.rutbe5 then
			local row5 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row5, 1, v.rutbe5)
			local r, g, b = getColorFromString(v.rutbe5r)
			dgsGridListSetItemColor(klanRutbeler2, row5, 1, r, g, b)
		end
	end
	for _, v in ipairs(arg3) do
		local r2, g2, b2 = r, g, b
		local row, row2, row3, row4
		for _, j in ipairs(arg6) do
			if (j.rutbe1r) and v.rutbe == j.rutbe1 then
				r2, g2, b2 = getColorFromString(j.rutbe1r)
			elseif (j.rutbe2r) and v.rutbe == j.rutbe1 then
				r2, g2, b2 = getColorFromString(j.rutbe2r)
			elseif (j.rutbe3r) and v.rutbe == j.rutbe1 then
				r2, g2, b2 = getColorFromString(j.rutbe3r)
			elseif (j.rutbe4r) and v.rutbe == j.rutbe1 then
				r2, g2, b2 = getColorFromString(j.rutbe4r)
			elseif (j.rutbe5r) and v.rutbe == j.rutbe1 then
				r2, g2, b2 = getColorFromString(j.rutbe5r)
			end
		end
		if arg5 == "user" then
			row = dgsGridListAddRow(takimListesi)
			row2 = dgsGridListAddRow(takimListesi2)
		elseif arg5 == "yetkili" then
			row3 = dgsGridListAddRow(yetkiliTakimdakiler)
			row4 = dgsGridListAddRow(yetkiliTakimdakiler2)
		end
		if arg5 == "user" then
			dgsGridListSetItemText(takimListesi, row, 1, removeColorCoding(v.player))
			dgsGridListSetItemText(takimListesi, row, 2, v.rutbe)
			dgsGridListSetItemText(takimListesi, row, 3, v.kazanma)
			dgsGridListSetItemText(takimListesi2, row2, 1, removeColorCoding(v.player))
			dgsGridListSetItemText(takimListesi2, row2, 2, v.rutbe)
			dgsGridListSetItemText(takimListesi2, row2, 3, v.kazanma)
		elseif arg5 == "yetkili" then
			dgsGridListSetItemData(yetkiliTakimdakiler, row3, 1, v.hesapIsmi)
			dgsGridListSetItemText(yetkiliTakimdakiler, row3, 1, removeColorCoding(v.player))
			dgsGridListSetItemText(yetkiliTakimdakiler, row3, 2, v.rutbe)
			dgsGridListSetItemText(yetkiliTakimdakiler, row3, 3, v.kazanma)
			dgsGridListSetItemData(yetkiliTakimdakiler2, row4, 1, v.hesapIsmi)
			dgsGridListSetItemText(yetkiliTakimdakiler2, row4, 1, removeColorCoding(v.player))
			dgsGridListSetItemText(yetkiliTakimdakiler2, row4, 2, v.rutbe)
			dgsGridListSetItemText(yetkiliTakimdakiler2, row4, 3, v.kazanma)
		end
		if v.durum == "Çevrimiçi" then
			if arg5 == "user" then
				dgsGridListSetItemColor(takimListesi, row, 1, 0, 255, 0)
				dgsGridListSetItemColor(takimListesi, row, 2, r2, g2, b2)
				dgsGridListSetItemColor(takimListesi, row, 3, 0, 255, 0)
				dgsGridListSetItemColor(takimListesi2, row2, 1, 0, 255, 0)
				dgsGridListSetItemColor(takimListesi2, row2, 2, r2, g2, b2)
				dgsGridListSetItemColor(takimListesi2, row2, 3, 0, 255, 0)
			elseif arg5 == "yetkili" then
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 1, 0, 255, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 2, r2, g2, b2)
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 3, 0, 255, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 1, 0, 255, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 2, r2, g2, b2)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 3, 0, 255, 0)
			end
		else
			if arg5 == "user" then
				dgsGridListSetItemColor(takimListesi, row, 1, 255, 0, 0)
				dgsGridListSetItemColor(takimListesi, row, 2, r2, g2, b2)
				dgsGridListSetItemColor(takimListesi, row, 3, 255, 0, 0)
				dgsGridListSetItemColor(takimListesi2, row2, 1, 255, 0, 0)
				dgsGridListSetItemColor(takimListesi2, row2, 2, r2, g2, b2)
				dgsGridListSetItemColor(takimListesi2, row2, 3, 255, 0, 0)
			elseif arg5 == "yetkili" then
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 1, 255, 0, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 2, r2, g2, b2)
				dgsGridListSetItemColor(yetkiliTakimdakiler, row3, 3, 255, 0, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 1, 255, 0, 0)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 2, r2, g2, b2)
				dgsGridListSetItemColor(yetkiliTakimdakiler2, row4, 3, 255, 0, 0)
			end
		end
	end
end
addEvent("seçilenTakım", true)
addEventHandler("seçilenTakım", root, secilenTakim)

function davetEngelleClick(btn, state)
	if btn == "left" and state == "down" then
		if dgsCheckBoxGetSelected(cbDavetEngelle) then
			triggerServerEvent("setPlayerAccountData", getLocalPlayer(), "1")
			dgsSetVisible(beklemeEkrani, true)
		else
			triggerServerEvent("setPlayerAccountData", getLocalPlayer(), "0")
			dgsSetVisible(beklemeEkrani, true)
		end
	end
end

