function takvimResimAyarla(rd)
	if dxGetPixelsFormat(rd) then
		dgsSetProperty(takimKurulusR, "image", dxCreateTexture(rd))
		dgsSetProperty(takimKurulusR2, "image", dxCreateTexture(rd))
	end
end
addEvent("takvimResimAyarla",true)
addEventHandler("takvimResimAyarla", root, takvimResimAyarla)

function tiklama(b, s)
	if b == "left" and s == "down" then
		local seciliKisi = secilen(yetkiliKisiler)
		local seciliKisi2 = secilen(yetkiliKisiler2)
		if source == takimaAt then
			if seciliKisi then
				if secilen(yetkiliTakimlar) then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "gönder", seciliKisi, secilen(yetkiliTakimlar))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == takimaAt2 then
			if seciliKisi2 then
				if secilen(yetkiliTakimlar2) then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "gönder", seciliKisi2, secilen(yetkiliTakimlar2))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
			
		elseif source == takimdanAt then
			if secilen(yetkiliTakimdakiler) then
				if secilen(yetkiliTakimlar) then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "at", secilen(yetkiliTakimdakiler), secilen(yetkiliTakimlar))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == takimdanAt2 then
			if secilen(yetkiliTakimdakiler2) then
				if secilen(yetkiliTakimlar2) then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "at", secilen(yetkiliTakimdakiler2), secilen(yetkiliTakimlar2))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == rutbeDuzenleYetkili then
			if secilen(yetkiliTakimlar) then
				if secilen(yetkiliTakimdakiler) then
					dgsSetVisible(rutbeDuzenleP, true)
					dgsSetVisible(wndClanPanel, false)
					degisken = "klan"
				else
					outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == rutbeDuzenleYetkili2 then
			if secilen(yetkiliTakimlar2) then
				if secilen(yetkiliTakimdakiler2) then
					dgsSetVisible(rutbeDuzenleP, true)
					dgsSetVisible(wndClanOlustur, false)
					degisken = "olustur"
				else
					outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == rutbeDuzenlePKapatL then
			dgsSetVisible(rutbeDuzenleP, false)
			if degisken == "olustur" then
				dgsSetVisible(wndClanOlustur, true)
			elseif degisken == "klan" then
				dgsSetVisible(wndClanPanel, true)
			end
		elseif source == rutbeDuzenleVer then
			local index = dgsGridListGetSelectedItem(klanRutbeler2)
			if index == -1 then
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			else
				if degisken == "olustur" then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "rütbeVer", secilen(yetkiliTakimdakiler2), dgsGridListGetItemText(klanRutbeler2, index, 1), secilen(yetkiliTakimlar2))
					dgsSetVisible(beklemeEkrani, true)
				elseif degisken == "klan" then
					triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "rütbeVer", secilen(yetkiliTakimdakiler), dgsGridListGetItemText(klanRutbeler, index, 1), secilen(yetkiliTakimlar))
					dgsSetVisible(beklemeEkrani, true)
				end
			end
		elseif source == rutbeDuzenleAl then
			triggerServerEvent("oyuncuyaİşlevYap", getLocalPlayer(), "rütbeAl", secilen(yetkiliTakimdakiler2))
			dgsSetVisible(beklemeEkrani, true)
		elseif source == takimGecmis then
			dgsSetVisible(takimGecmisP, true)
			dgsSetVisible(wndClanPanel, false)
		elseif source == takimGecmisPKapatL then
			dgsSetVisible(takimGecmisP, false)
			dgsSetVisible(wndClanPanel, true)
		elseif source == odulVer then
			if secilen(gridClanUyeler) then
				triggerServerEvent("ödülVer", getLocalPlayer(), secilen(gridClanUyeler))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == yetkiliOdulVer then
			if secilen(yetkiliTakimlar) then
				if secilen(yetkiliTakimdakiler) then
					triggerServerEvent("ödülVer", getLocalPlayer(), secilen(yetkiliTakimdakiler), secilen(yetkiliTakimlar))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == yetkiliOdulVer2 then
			if secilen(yetkiliTakimlar2) then
				if secilen(yetkiliTakimdakiler2) then
					triggerServerEvent("ödülVer", getLocalPlayer(), secilen(yetkiliTakimdakiler2), secilen(yetkiliTakimlar2))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == oyuncuAra then
			dgsLabelSetColor(oyuncuAraL, 128, 128, 128)
		elseif source == oyuncuAra2 then
			dgsLabelSetColor(oyuncuAraL2, 128, 128, 128)
		else
			dgsLabelSetColor(oyuncuAraL, 64, 64, 64)
			dgsLabelSetColor(oyuncuAraL2, 64, 64, 64)
		end
	end
end
addEventHandler("onDgsMouseClick", root, tiklama)

addEventHandler("onClientGUIClick", root,
function()
	dgsLabelSetColor(oyuncuAraL, 64, 64, 64)
	dgsLabelSetColor(oyuncuAraL2, 64, 64, 64)
end)

function sunucuUyeleri(tablo)
	table = tablo
	dgsGridListClearRow(yetkiliKisiler)
	dgsGridListClearRow(yetkiliKisiler2)
	for i = 1, #tablo do
		local row1 = dgsGridListAddRow(yetkiliKisiler)
		dgsGridListSetItemData(yetkiliKisiler, row1, 1, tablo[i].hesapIsmi)
		dgsGridListSetItemText(yetkiliKisiler, row1, 1, tablo[i].kisiIsmi.." #FFFFFF("..tablo[i].hesapIsmi..")")
		dgsGridListSetItemColor(yetkiliKisiler, row1, 1, 255, 255, 255)
		local row2 = dgsGridListAddRow(yetkiliKisiler2)
		dgsGridListSetItemData(yetkiliKisiler2, row2, 1, tablo[i].hesapIsmi)
		dgsGridListSetItemText(yetkiliKisiler2, row2, 1, tablo[i].kisiIsmi.." #FFFFFF("..tablo[i].hesapIsmi..")")
		dgsGridListSetItemColor(yetkiliKisiler2, row2, 1, 255, 255, 255)
	end
end
addEventHandler("sunucuÜyeleri", root, sunucuUyeleri)

function onDgsTextChange()
	if source == oyuncuAra then
		dgsGridListClearRow(yetkiliKisiler)
		local text = dgsGetText(oyuncuAra)
		if (text == "") then
			dgsSetText(oyuncuAraL, "OYUNCU ARA")
			for i = 1, #table do
				local row = dgsGridListAddRow(yetkiliKisiler)
				dgsGridListSetItemData(yetkiliKisiler, row, 1, table[i].hesapIsmi)
				dgsGridListSetItemText(yetkiliKisiler, row, 1, table[i].kisiIsmi.." #FFFFFF("..table[i].hesapIsmi..")")
				dgsGridListSetItemColor(yetkiliKisiler, row, 1, 255, 255, 255)
			end
		else
			dgsSetText(oyuncuAraL, "")
			for i = 1, #table do
				if string.find(string.upper(removeColorCoding(table[i].kisiIsmi)), string.upper(text), 1, true) or string.find(string.upper(table[i].hesapIsmi), string.upper(text), 1, true) then
					local row = dgsGridListAddRow(yetkiliKisiler)
					dgsGridListSetItemData(yetkiliKisiler, row, 1, table[i].hesapIsmi)
					dgsGridListSetItemText(yetkiliKisiler, row, 1, table[i].kisiIsmi.." #FFFFFF("..table[i].hesapIsmi..")")
					dgsGridListSetItemColor(yetkiliKisiler, row, 1, 255, 255, 255)
				end
			end
		end
	elseif source == oyuncuAra2 then
		dgsGridListClearRow(yetkiliKisiler2)
		local text = dgsGetText(oyuncuAra2)
		if (text == "") then
			dgsSetText(oyuncuAraL2, "OYUNCU ARA")
			for i = 1, #table do
				local row = dgsGridListAddRow(yetkiliKisiler2)
				dgsGridListSetItemData(yetkiliKisiler2, row, 1, table[i].hesapIsmi)
				dgsGridListSetItemText(yetkiliKisiler2, row, 1, table[i].kisiIsmi.." #FFFFFF("..table[i].hesapIsmi..")")
				dgsGridListSetItemColor(yetkiliKisiler2, row, 1, 255, 255, 255)
			end
		else
			dgsSetText(oyuncuAraL2, "")
			for i = 1, #table do
				if string.find(string.upper(removeColorCoding(table[i].kisiIsmi)), string.upper(text), 1, true) or string.find(string.upper(table[i].hesapIsmi), string.upper(text), 1, true) then
					local row = dgsGridListAddRow(yetkiliKisiler2)
					dgsGridListSetItemData(yetkiliKisiler2, row, 1, table[i].hesapIsmi)
					dgsGridListSetItemText(yetkiliKisiler2, row, 1, table[i].kisiIsmi.." #FFFFFF("..table[i].hesapIsmi..")")
					dgsGridListSetItemColor(yetkiliKisiler2, row, 1, 255, 255, 255)
				end
			end
		end
	end
end
addEventHandler("onDgsTextChange", root, onDgsTextChange)

function createDavetGeldi()
	wndDavetGeldi = dgsCreateImage(screenx/2-290/2, screeny/2-106/2-(350), 290, 106, "Parcalar/resim.png", false, _, tocolor(0, 0, 0, 128))
	dgsSetVisible(wndDavetGeldi, false)
	lblDavetGeldi = dgsCreateLabel(8, 20, 275, 26, "Clan ismi --- takımından davet geldi ?", false, wndDavetGeldi)
	dgsLabelSetHorizontalAlign(lblDavetGeldi, "center", false)
	dgsLabelSetVerticalAlign(lblDavetGeldi, "center")
	btnDavetKabul = dgsCreateButton(9, 74, 68, 21, "Evet", false, wndDavetGeldi)
	btnDavetNo = dgsCreateButton(212, 74, 68, 21, "Hayır", false, wndDavetGeldi)
	addEventHandler("onDgsMouseClick", btnDavetNo, davetReddet, false)
	addEventHandler("onDgsMouseClick", btnDavetKabul, davetKabul, false)
end
				
function davetReddet(btn)
	if btn == "left" then
		triggerServerEvent("davetReddet", getLocalPlayer())
		dgsSetVisible(beklemeEkrani, true)
		showCursor(false)
		dgsSetVisible(wndDavetGeldi, false)

		setElementData(getLocalPlayer(), "clanpanel", "false")

	end
end

function davetKabul(btn)
	if btn == "left" then
		triggerServerEvent("davetKabul", getLocalPlayer())
		dgsSetVisible(beklemeEkrani, true)
		showCursor(false)
		dgsSetVisible(wndDavetGeldi, false)

		setElementData(getLocalPlayer(), "clanpanel", "false")

	end
end

function cPanelCikis(btn)
	if btn == "left" then
		closePicker("klan")
		closePicker("olustur")
		showCursor(false)
		dgsSetVisible(wndClanPanel, false)
		setElementData(getLocalPlayer(), "clanpanel", "false")
	end
end
addEvent("takımPaneliniKapat", true)
addEventHandler("takımPaneliniKapat", root, cPanelCikis)

function coDevam(btn, st)
	if btn == "left" and st == "down" then
		local money = tonumber(getElementData(getLocalPlayer(), "Cash"))
		local renk = dgsGetText(txtCORenk)
		local r, g, b = getColorFromString(renk)
		local isim, tag, bi1, bi2 = dgsGetText(txtCOIsim), dgsGetText(txtCOTag), dgsGetText(takimbilgisi1E), dgsGetText(takimbilgisi2E)
		if r == false then
			outputChatBox(tRenkY..fRenk.." Renk kodu"..aRenk.." hatalı", 0, 0, 0, true)
		elseif #isim <=0 then
			outputChatBox(tRenkY..fRenk.." Takım ismi"..aRenk.." hatalı", 0, 0, 0, true)
		elseif #tag <=0 then
			outputChatBox(tRenkY..fRenk.." Takım tagı"..aRenk.." hatalı", 0, 0, 0, true)
		else
			dgsSetVisible(wndClanOlustur, false)
			dgsSetVisible(wndClanPanel, false)
			showCursor(false)
			triggerServerEvent("clanKur", getLocalPlayer(), isim, tag, renk, tostring(r), tostring(g), tostring(b), bi1, bi2)
			dgsSetVisible(beklemeEkrani, true)
		end
	end
end

function coVazgec(btn)
	if btn == "left" then
		closePicker("klan")
		closePicker("olustur")
		dgsSetVisible(wndClanOlustur, false)
		setElementData(getLocalPlayer(), "clanpanel", "false")
		showCursor(false)
		guiSetInputEnabled(false)
	end
end

function clanKapat()
	dgsSetVisible(wndClanOlustur, false)
	showCursor(false)
	setElementData(getLocalPlayer(), "clanpanel", "false")
end
addEvent("clanKapat", true)
addEventHandler("clanKapat", getRootElement(), clanKapat)

function clanYok(davetengelle, yetkim)
	if tonumber(davetengelle) == 1 then
		dgsCheckBoxSetSelected(cbDavetEngelle, true)
	else
		dgsCheckBoxSetSelected(cbDavetEngelle, false)
	end
	dgsSetVisible(tab3olustur, yetkim)
	dgsSetVisible(wndClanOlustur, true)
	showCursor(true)
	setElementData(getLocalPlayer(), "clanpanel", "true")
	guiSetInputEnabled(true)
end
addEvent("clanYok", true)
addEventHandler("clanYok", getRootElement(), clanYok)

function clanPanelCikisYap()
	cPanelCikis("left")
end
addEvent("clanPanelCikisYap", true)
addEventHandler("clanPanelCikisYap", getRootElement(), clanPanelCikisYap)

function ClanDevret()
	ClanDevretW = dgsCreateImage(screenx/2-290/2, screeny/2-106/2-(350), 290, 106, "Parcalar/resim.png", false, _, tocolor(0, 0, 0, 128))
	dgsSetVisible(ClanDevretW, false)
	ClanDevretW22 = dgsCreateLabel(8, 20, 275, 26, "Clan Devredilecek, EMİN misiniz?", false, ClanDevretW)
	dgsLabelSetVerticalAlign(ClanDevretW22, "center")
	dgsLabelSetHorizontalAlign(ClanDevretW22, "center", true)
	DevretClan = dgsCreateButton(9, 74, 68, 21, "Evet", false, ClanDevretW)
	DevretVazgec = dgsCreateButton(212, 74, 68, 21, "Vazgec", false, ClanDevretW)
	addEventHandler("onDgsMouseClick", DevretVazgec, VazgecDevretme, false)
	addEventHandler("onDgsMouseClick", DevretClan, DevretClani, false)
end

function VazgecDevretme()
	dgsSetVisible(ClanDevretW, false)
end

function DevretClani()
	dgsSetVisible(ClanDevretW, false)
	if secilen(gridClanUyeler) then
		triggerServerEvent("clanDevret", getLocalPlayer(), secilen(gridClanUyeler))
		dgsSetVisible(beklemeEkrani, true)
	else
		outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
	end
end

function gecmisYaz(tablo)
	dgsGridListClearRow(takimGecmisListe)
	for i, item in ipairs(tablo) do
		local row = dgsGridListAddRow(takimGecmisListe)
		dgsGridListSetItemText(takimGecmisListe, row, 1, item.veri)
	end
end
addEvent("takımGeçmişi", true)
addEventHandler("takımGeçmişi", root, gecmisYaz)

function rutbeleriYaz(tablo)
	dgsGridListClearRow(klanRutbeler)
	dgsGridListClearRow(klanRutbeler2)
	for i, v in ipairs(tablo) do
		if v.rutbe1 then
			local row1 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row1, 1, v.rutbe1)
			local r, g, b = getColorFromString(v.rutbe1r)
			dgsGridListSetItemColor(klanRutbeler, row1, 1, r, g, b)
			local row1 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row1, 1, v.rutbe1)
			local r, g, b = getColorFromString(v.rutbe1r)
			dgsGridListSetItemColor(klanRutbeler2, row1, 1, r, g, b)
		end
		if v.rutbe2 then
			local row2 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row2, 1, v.rutbe2)
			local r, g, b = getColorFromString(v.rutbe2r)
			dgsGridListSetItemColor(klanRutbeler, row2, 1, r, g, b)
			local row2 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row2, 1, v.rutbe2)
			local r, g, b = getColorFromString(v.rutbe2r)
			dgsGridListSetItemColor(klanRutbeler2, row2, 1, r, g, b)
		end
		if v.rutbe3 then
			local row3 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row3, 1, v.rutbe3)
			local r, g, b = getColorFromString(v.rutbe3r)
			dgsGridListSetItemColor(klanRutbeler, row3, 1, r, g, b)
			local row3 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row3, 1, v.rutbe3)
			local r, g, b = getColorFromString(v.rutbe3r)
			dgsGridListSetItemColor(klanRutbeler2, row3, 1, r, g, b)
		end
		if v.rutbe4 then
			local row4 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row4, 1, v.rutbe4)
			local r, g, b = getColorFromString(v.rutbe4r)
			dgsGridListSetItemColor(klanRutbeler, row4, 1, r, g, b)
			local row4 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row4, 1, v.rutbe4)
			local r, g, b = getColorFromString(v.rutbe4r)
			dgsGridListSetItemColor(klanRutbeler2, row4, 1, r, g, b)
		end
		if v.rutbe5 then
			local row5 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row5, 1, v.rutbe5)
			local r, g, b = getColorFromString(v.rutbe5r)
			dgsGridListSetItemColor(klanRutbeler, row5, 1, r, g, b)
			local row5 = dgsGridListAddRow(klanRutbeler2)
			dgsGridListSetItemText(klanRutbeler2, row5, 1, v.rutbe5)
			local r, g, b = getColorFromString(v.rutbe5r)
			dgsGridListSetItemColor(klanRutbeler2, row5, 1, r, g, b)
		end
	end
end
addEvent("rütbeleriYaz", true)
addEventHandler("rütbeleriYaz", root, rutbeleriYaz)

function clanPanelAc(isim, tag, red, green, blue, kurucu, yetki, uyeler, rutbeler, bilgi1, bilgi2, rutbe, takimPuani, takimKurulusu, takimOdulS, takimSirasi, yetkim)
	dgsSetVisible(tab3klan, yetkim)
	dgsGridListClearRow(gridClanUyeler)
	dgsGridListClearRow(klanUyeler)
	dgsGridListClearRow(klanRutbeler)
	dgsGridListClearRow(klanRutbeler2)
	for i, v in ipairs(yetki) do
		if v.rutbeB1 == tostring(true) then v.rutbeB1 = false else v.rutbeB1 = true end
		if v.rutbeB2 == tostring(true) then v.rutbeB2 = false else v.rutbeB2 = true end
		if v.rutbeIsim == tostring(true) then v.rutbeIsim = false else v.rutbeIsim = true end
		if v.rutbeTag == tostring(true) then v.rutbeTag = false else v.rutbeTag = true end
		if v.rutbeDuzen == tostring(true) then v.rutbeDuzen = false else v.rutbeDuzen = true end
		if v.rutbeOdul == tostring(true) then v.rutbeOdul = false else v.rutbeOdul = true end
		if v.rutbeDavet == tostring(true) then v.rutbeDavet = false else v.rutbeDavet = true end
		if v.rutbeAt == tostring(true) then v.rutbeAt = false else v.rutbeAt = true end
		if v.rutbeRenk == tostring(true) then v.rutbeRenk = false else v.rutbeRenk = true end
		if v.rutbeVer == tostring(true) then v.rutbeVer = false else v.rutbeVer = true end
		if v.rutbe == rutbe then
			if v.rutbeDuzen == true then
				dgsSetEnabled(rutbeDuzenle, v.rutbeDuzen)
			elseif v.rutbeVer == true then
				dgsSetEnabled(rutbeDuzenle, v.rutbeVer)
			end
			dgsSetEnabled(yeniRutbe, v.rutbeDuzen)
			dgsSetEnabled(rutbeKaydet, v.rutbeDuzen)
			dgsSetEnabled(rutbeSil, v.rutbeDuzen)
			dgsSetEnabled(rutbeRengiE, v.rutbeDuzen)
			dgsSetEnabled(rutbeRengiB, v.rutbeDuzen)
			dgsSetEnabled(rutbeIsmi, v.rutbeDuzen)
			dgsSetEnabled(rutbeVer, v.rutbeVer)
			dgsSetEnabled(rutbeAl, v.rutbeVer)
			dgsSetEnabled(btnClanDavetEt, v.rutbeDavet)
			dgsSetEnabled(btnClanAt, v.rutbeAt)
			dgsSetEnabled(renkdegis, v.rutbeRenk)
			dgsSetEnabled(odulVer, v.rutbeOdul)
			dgsSetEnabled(renkButon, v.rutbeRenk)
			dgsSetEnabled(renkEdit, v.rutbeRenk)
			dgsSetEnabled(tTagB, v.rutbeTag)
			dgsSetEnabled(tTagE, v.rutbeTag)
			dgsSetEnabled(tIsimE, v.rutbeIsim)
			dgsSetEnabled(tIsimB, v.rutbeIsim)
			dgsSetEnabled(takimbilgisi1EB2, v.rutbeB1)
			dgsSetEnabled(takimbilgisi1D, v.rutbeB1)
			dgsSetEnabled(takimbilgisi2EB2, v.rutbeB2)
			dgsSetEnabled(takimbilgisi2D, v.rutbeB2)
		end
	end
	if tonumber(kurucu) == 1 then
		dgsSetEnabled(yeniRutbe, true)
		dgsSetEnabled(rutbeKaydet, true)
		dgsSetEnabled(rutbeSil, true)
		dgsSetEnabled(rutbeRengiE, true)
		dgsSetEnabled(rutbeRengiB, true)
		dgsSetEnabled(rutbeIsmi, true)
		dgsSetEnabled(btnClanDevret, true)
		dgsSetEnabled(btnClanKapat, true)
		dgsSetEnabled(rutbeDuzenle, true)
		dgsSetEnabled(btnClanDavetEt, true)
		dgsSetEnabled(btnClanAt, true)
		dgsSetEnabled(btnClanAyril, false)
		dgsSetEnabled(renkdegis, true)
		dgsSetEnabled(odulVer, true)
		dgsSetEnabled(renkButon, true)
		dgsSetEnabled(renkEdit, true)
		dgsSetEnabled(tTagB, true)
		dgsSetEnabled(tTagE, true)
		dgsSetEnabled(tIsimE, true)
		dgsSetEnabled(tIsimB, true)
		dgsSetEnabled(takimbilgisi1EB2, true)
		dgsSetEnabled(takimbilgisi1D, true)
		dgsSetEnabled(takimbilgisi2EB2, true)
		dgsSetEnabled(takimbilgisi2D, true)
		dgsSetEnabled(gecmisSil, true)
		dgsSetEnabled(rutbeVer, true)
		dgsSetEnabled(rutbeAl, true)
	elseif rutbe == "Üye" then
		dgsSetEnabled(yeniRutbe, false)
		dgsSetEnabled(rutbeKaydet, false)
		dgsSetEnabled(rutbeSil, false)
		dgsSetEnabled(rutbeRengiE, false)
		dgsSetEnabled(rutbeRengiB, false)
		dgsSetEnabled(rutbeIsmi, false)
		dgsSetEnabled(btnClanDevret, false)
		dgsSetEnabled(btnClanKapat, false)
		dgsSetEnabled(rutbeDuzenle, false)
		dgsSetEnabled(btnClanDavetEt, false)
		dgsSetEnabled(btnClanAt, false)
		dgsSetEnabled(btnClanAyril, true)
		dgsSetEnabled(renkdegis, false)
		dgsSetEnabled(odulVer, false)
		dgsSetEnabled(renkButon, false)
		dgsSetEnabled(renkEdit, false)
		dgsSetEnabled(tTagB, false)
		dgsSetEnabled(tTagE, false)
		dgsSetEnabled(tIsimE, false)
		dgsSetEnabled(tIsimB, false)
		dgsSetEnabled(takimbilgisi1EB2, false)
		dgsSetEnabled(takimbilgisi1D, false)
		dgsSetEnabled(takimbilgisi2EB2, false)
		dgsSetEnabled(takimbilgisi2D, false)
		dgsSetEnabled(gecmisSil, false)
		dgsSetEnabled(rutbeVer, false)
		dgsSetEnabled(rutbeAl, false)
	end
	for i, v in ipairs(rutbeler) do		
		if v.rutbe1 then
			local row1 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row1, 1, v.rutbe1)
			local r, g, b = getColorFromString(v.rutbe1r)
			dgsGridListSetItemColor(klanRutbeler, row1, 1, r, g, b)
		end
		if v.rutbe2 then
			local row2 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row2, 1, v.rutbe2)
			local r, g, b = getColorFromString(v.rutbe2r)
			dgsGridListSetItemColor(klanRutbeler, row2, 1, r, g, b)
		end
		if v.rutbe3 then
			local row3 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row3, 1, v.rutbe3)
			local r, g, b = getColorFromString(v.rutbe3r)
			dgsGridListSetItemColor(klanRutbeler, row3, 1, r, g, b)
		end
		if v.rutbe4 then
			local row4 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row4, 1, v.rutbe4)
			local r, g, b = getColorFromString(v.rutbe4r)
			dgsGridListSetItemColor(klanRutbeler, row4, 1, r, g, b)
		end
		if v.rutbe5 then
			local row5 = dgsGridListAddRow(klanRutbeler)
			dgsGridListSetItemText(klanRutbeler, row5, 1, v.rutbe5)
			local r, g, b = getColorFromString(v.rutbe5r)
			dgsGridListSetItemColor(klanRutbeler, row5, 1, r, g, b)
		end
	end
	for i, v in ipairs(uyeler) do
		local row = dgsGridListAddRow(gridClanUyeler)
		local row2 = dgsGridListAddRow(klanUyeler)
		dgsGridListSetItemData(gridClanUyeler, row, 1, v.playerD)
		dgsGridListSetItemText(gridClanUyeler, row, 1, removeColorCoding(v.player))
		dgsGridListSetItemText(gridClanUyeler, row, 2, v.rutbe)
		dgsGridListSetItemText(gridClanUyeler, row, 3, v.kazanma)
		dgsGridListSetItemText(gridClanUyeler, row, 4, v.durum)
		dgsGridListSetItemData(klanUyeler, row2, 1, v.playerD)
		dgsGridListSetItemText(klanUyeler, row2, 1, removeColorCoding(v.player))
		dgsGridListSetItemText(klanUyeler, row2, 2, v.rutbe)
		for k, j in ipairs(rutbeler) do
			if (j.rutbe1r) and j.rutbe1 == v.rutbe then
				local r, g, b = getColorFromString(j.rutbe1r)
				dgsGridListSetItemColor(gridClanUyeler, row, 2, r, g, b)
				dgsGridListSetItemColor(klanUyeler, row2, 2, r, g, b)
			elseif (j.rutbe2r) and j.rutbe2 == v.rutbe then
				local r, g, b = getColorFromString(j.rutbe2r)
				dgsGridListSetItemColor(gridClanUyeler, row, 2, r, g, b)
				dgsGridListSetItemColor(klanUyeler, row2, 2, r, g, b)
			elseif (j.rutbe3r) and j.rutbe3 == v.rutbe then
				local r, g, b = getColorFromString(j.rutbe3r)
				dgsGridListSetItemColor(gridClanUyeler, row, 2, r, g, b)
				dgsGridListSetItemColor(klanUyeler, row2, 2, r, g, b)
			elseif (j.rutbe4r) and j.rutbe4 == v.rutbe then
				local r, g, b = getColorFromString(j.rutbe4r)
				dgsGridListSetItemColor(gridClanUyeler, row, 2, r, g, b)
				dgsGridListSetItemColor(klanUyeler, row2, 2, r, g, b)
			elseif (j.rutbe5r) and j.rutbe5 == v.rutbe then
				local r, g, b = getColorFromString(j.rutbe5r)
				dgsGridListSetItemColor(gridClanUyeler, row, 2, r, g, b)
				dgsGridListSetItemColor(klanUyeler, row2, 2, r, g, b)
			end
		end
		if v.durum == "Çevrimiçi" then
			dgsGridListSetItemColor(gridClanUyeler, row, 1, 0, 255, 0)
			dgsGridListSetItemColor(gridClanUyeler, row, 3, 0, 255, 0)
			dgsGridListSetItemColor(gridClanUyeler, row, 4, 0, 255, 0)
			dgsGridListSetItemColor(klanUyeler, row2, 1, 0, 255, 0)
		else
			dgsGridListSetItemColor(gridClanUyeler, row, 1, 255, 0, 0)
			dgsGridListSetItemColor(gridClanUyeler, row, 3, 255, 0, 0)
			dgsGridListSetItemColor(gridClanUyeler, row, 4, 255, 0, 0)
			dgsGridListSetItemColor(klanUyeler, row2, 1, 255, 0, 0)
		end
		if v.rutbe == "Üye" then
			dgsGridListSetItemColor(gridClanUyeler, row, 2, 0, 255, 0)
			dgsGridListSetItemColor(klanUyeler, row2, 2, 0, 255, 0)
		elseif v.rutbe == "Kurucu" then
			dgsGridListSetItemColor(gridClanUyeler, row, 2, red, green, blue)
			dgsGridListSetItemColor(klanUyeler, row2, 2, red, green, blue)
		end
	end
	dgsSetText(tIsimE, isim)
	dgsSetText(tTagE, tag)
	dgsSetText(takimbilgisi1EB2, bilgi1)
	dgsSetText(takimbilgisi2EB2, bilgi2)
	dgsSetText(renkEdit, string.format("#%.2X%.2X%.2X", red, green, blue))
	dgsSetProperty(renkEdit, "textColor", tocolor(red, green, blue, 255))
	dgsSetText(takimOdulSayi, "Takımdaki Ödüller: "..takimOdulS)
	dgsSetText(takimKurulus, "Takım Tarihi: "..takimKurulusu)
	dgsSetText(takimSira, "Takım Sırası - Puanı: "..takimSirasi..". Sıra - "..takimPuani.." Puan")
	dgsSetVisible(wndClanPanel, true)
	showCursor(true)
	guiSetInputEnabled(true)
	setElementData(getLocalPlayer(), "clanpanel", "true")
end
addEvent("clanPanelAc", true)
addEventHandler("clanPanelAc", getRootElement(), clanPanelAc)

function uygula(btn, s)
	if btn=="left" and s == "down" then
		if source == btnClanAyril then
			triggerServerEvent("clandanAyril", getLocalPlayer())
			dgsSetVisible(beklemeEkrani, true)
			cPanelCikis("left")
		elseif source == btnClanAt then
			if secilen(gridClanUyeler) then
				dgsSetVisible(ClandanAtmaW, true)
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == btnClanDevret then
			if secilen(gridClanUyeler) then
				dgsSetVisible(ClanDevretW, true)
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == btnClanKapat then
			dgsSetVisible(clanKapaltTest, true)
			showCursor(true)
		elseif source == rutbeDuzenle then
			dgsSetVisible(wndClanPanel, false)
			dgsSetVisible(YetkiAlmapenceresi, true)
		end
	end
end

function wndDavetGoster(uyeler, isim)
	dgsGridListClearRow(gridClanDavetUyeler)
	for _, v in ipairs(uyeler) do
		local row = dgsGridListAddRow(gridClanDavetUyeler)
		dgsGridListSetItemText(gridClanDavetUyeler, row, 1, v.name)
		dgsGridListSetItemData(gridClanDavetUyeler, row, 1, v.data)
	end
end
addEvent("wndDavetGoster", true)
addEventHandler("wndDavetGoster", getRootElement(), wndDavetGoster)

function davetEtPlayer(btn, s)
	if btn == "left" and s == "down" then
		local index = dgsGridListGetSelectedItem(gridClanDavetUyeler)
		if index == -1 then
			outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
		else
			triggerServerEvent("davetEtPlayer", getLocalPlayer(), dgsGridListGetItemData(gridClanDavetUyeler, index, 1))
			dgsSetVisible(beklemeEkrani, true)
		end
	end
end

function davetGeldi(clanismi)
	if clanismi then
		guiSetText(lblDavetGeldi, clanismi.." Takımına katılmak ister misin?")
		dgsSetVisible(wndDavetGeldi, true)
		showCursor(true)
	else
		triggerServerEvent("davetReddet", getLocalPlayer())
		dgsSetVisible(beklemeEkrani, true)
		setElementData(getLocalPlayer(), "clanpanel", "false")
	end
end
addEvent("davetGeldi", true)
addEventHandler("davetGeldi", getRootElement(), davetGeldi)

function closeClanTest()
	clanKapaltTest = dgsCreateImage(screenx/2-290/2, screeny/2-106/2-(350), 290, 106, "Parcalar/resim.png", false, _, tocolor(0, 0, 0, 128))
	dgsSetVisible(clanKapaltTest, false)
	clanKapalt22 = dgsCreateLabel(8, 20, 275, 26, "Takımı kapatmak istediğine emin misin ?", false, clanKapaltTest)
	dgsLabelSetVerticalAlign(clanKapalt22, "center")
	dgsLabelSetHorizontalAlign(clanKapalt22, "center", true)
	ClaniKapalt = dgsCreateButton(9, 74, 68, 21, "Evet", false, clanKapaltTest)
	clanKapaltVaz = dgsCreateButton(212, 74, 68, 21, "Hayır", false, clanKapaltTest)
	addEventHandler("onDgsMouseClick", clanKapaltVaz, KapaltMA, false)
	addEventHandler("onDgsMouseClick", ClaniKapalt, KapaltClani, false)
end

function KapaltMA()
	dgsSetVisible(clanKapaltTest, false)
end

function KapaltClani()
	dgsSetVisible(wndClanPanel, false)
	dgsSetVisible(clanKapaltTest, false)
	showCursor(false)
	triggerServerEvent("clanKapat", getLocalPlayer())
	dgsSetVisible(beklemeEkrani, true)
end

function ClandanAtma()
	ClandanAtmaW = dgsCreateImage(screenx/2-290/2, screeny/2-106/2-(350), 290, 106, "Parcalar/resim.png", false, _, tocolor(0, 0, 0, 128))
	dgsSetVisible(ClandanAtmaW, false)
	ClandanAtmaW2 = dgsCreateLabel(8, 20, 275, 26, "Takımdan atmak istediğine emin misin ?", false, ClandanAtmaW)
	dgsLabelSetVerticalAlign(ClandanAtmaW2, "center")
	dgsLabelSetHorizontalAlign(ClandanAtmaW2, "center", true)
	ClandanAt = dgsCreateButton(9, 74, 68, 21, "Evet", false, ClandanAtmaW)
	ClantanAtVaz = dgsCreateButton(212, 74, 68, 21, "Hayır", false, ClandanAtmaW)
	addEventHandler("onDgsMouseClick", ClantanAtVaz, CladanAtmaVazgec, false)
	addEventHandler("onDgsMouseClick", ClandanAt, ClandanAtG, false)
end

function CladanAtmaVazgec()
	dgsSetVisible(ClandanAtmaW, false)
	showCursor(true)
end

function ClandanAtG()
	dgsSetVisible(ClandanAtmaW, false)
	if secilen(gridClanUyeler) then
		triggerServerEvent("clanUyeAt", getLocalPlayer(), secilen(gridClanUyeler))
		dgsSetVisible(beklemeEkrani, true)
	else
		outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
	end
end

function YetkiAlma()
	YetkiAlmapenceresi = dgsCreateWindow(screenx/2-355/2, screeny/2-465/2, 355, 465, "Rütbe Düzenle", false)
	dgsSetVisible(YetkiAlmapenceresi, false)
	dgsWindowSetMovable(YetkiAlmapenceresi, false)
	dgsWindowSetSizable(YetkiAlmapenceresi, false)
	YetkiAlmapenceresiKapat = dgsCreateImage(355-40, -25, 40, 25, "Parcalar/resim.png", false, YetkiAlmapenceresi, tocolor(200, 50, 50, 255))
	YetkiAlmapenceresiKapatL = dgsCreateLabel(0, 0, 40, 25, "×", false, YetkiAlmapenceresiKapat)
	dgsSetFont(YetkiAlmapenceresiKapatL, "default-bold")
	dgsLabelSetHorizontalAlign(YetkiAlmapenceresiKapatL, "center", false)
	dgsLabelSetVerticalAlign(YetkiAlmapenceresiKapatL, "center")
	klanUyeler = dgsCreateGridList(10, 10, 162.5, 220, false, YetkiAlmapenceresi)
	dgsGridListAddColumn(klanUyeler, "Kişiler", 0.58)
	dgsGridListAddColumn(klanUyeler, "Rütbe", 0.32)
	local klanUyelerScroll = dgsGetProperty(klanUyeler, "scrollbars")
	dgsSetProperty(klanUyelerScroll, "arrowColor", {tocolor(20, 20, 20, 255), tocolor(100, 100, 100, 255), tocolor(40, 40, 40, 255)})
	dgsSetProperty(klanUyelerScroll, "cursorColor", {tocolor(80, 80, 80, 255), tocolor(100, 100, 100, 255), tocolor(40, 40, 40, 255)})
	dgsSetProperty(klanUyelerScroll, "troughColor", tocolor(10, 10, 10, 255))
	klanRutbeler = dgsCreateGridList(182.5, 10, 162.5, 220, false, YetkiAlmapenceresi)
	dgsGridListAddColumn(klanRutbeler, "Rütbeler", 0.92)
	local klanRutbelerScroll = dgsGetProperty(klanRutbeler, "scrollbars")
	dgsSetProperty(klanRutbelerScroll, "arrowColor", {tocolor(20, 20, 20, 255), tocolor(100, 100, 100, 255), tocolor(40, 40, 40, 255)})
	dgsSetProperty(klanRutbelerScroll, "cursorColor", {tocolor(80, 80, 80, 255), tocolor(100, 100, 100, 255), tocolor(40, 40, 40, 255)})
	dgsSetProperty(klanRutbelerScroll, "troughColor", tocolor(10, 10, 10, 255))
	tBilgi1 = dgsCreateCheckBox(10, 240, 115, 25, "Takım Bilgisi 1", false, false, YetkiAlmapenceresi)
	tBilgi2 = dgsCreateCheckBox(10, 265, 115, 25, "Takım Bilgisi 2", false, false, YetkiAlmapenceresi)
	tIsmi = dgsCreateCheckBox(10, 290, 85, 25, "Takım İsmi", false, false, YetkiAlmapenceresi)
	tTagi = dgsCreateCheckBox(10, 315, 85, 25, "Takım Tagı", false, false, YetkiAlmapenceresi)
	tRutbeDuzen = dgsCreateCheckBox(10, 340, 85, 25, "Rütbe Düzenle", false, false, YetkiAlmapenceresi)
	tOdulVer = dgsCreateCheckBox(135, 240, 85, 25, "Ödül Ver", false, false, YetkiAlmapenceresi)
	tDavetEt = dgsCreateCheckBox(135, 265, 85, 25, "Davet Et", false, false, YetkiAlmapenceresi)
	tAt = dgsCreateCheckBox(135, 290, 85, 25, "Takımdan At", false, false, YetkiAlmapenceresi)
	tRenk = dgsCreateCheckBox(135, 315, 85, 25, "Renk Değiştir", false, false, YetkiAlmapenceresi)
	tRutbeVerAl = dgsCreateCheckBox(135, 340, 85, 25, "Rütbe Verme/Alma", false, false, YetkiAlmapenceresi)
	yeniRutbe = dgsCreateButton(10, 370, 80, 25, "Yeni Rütbe", false, YetkiAlmapenceresi)
	rutbeKaydet = dgsCreateButton(95, 370, 50, 25, "Kaydet", false, YetkiAlmapenceresi)
	rutbeSil = dgsCreateButton(150, 370, 50, 25, "Sil", false, YetkiAlmapenceresi)
	rutbeVer = dgsCreateButton(205, 370, 70, 25, "Rütbe Ver", false, YetkiAlmapenceresi)
	rutbeAl = dgsCreateButton(280, 370, 65, 25, "Rütbe Al", false, YetkiAlmapenceresi)
	rutbeRengiE = dgsCreateEdit(10, 405, 95, 25, "", false, YetkiAlmapenceresi)
	rutbeRengiB = dgsCreateButton(85, 0, 10, 25, "#", false, rutbeRengiE)
	addEventHandler("onDgsMouseClick", rutbeRengiB, adssda, false)
	rutbeIsmi = dgsCreateEdit(110, 405, 130, 25, "", false, YetkiAlmapenceresi)
	gecmisSil = dgsCreateButton(245, 405, 100, 25, "Geçmişi Sil", false, YetkiAlmapenceresi)
end

addEventHandler("onDgsMouseClick", root, 
function(b, s)
	if b == "left" and s == "down" then
		if source == tab1olustur then
			dgsSetVisible(tab1OBG, true)
			dgsSetVisible(tab2OBG, false)
			dgsSetVisible(tab3OBG, false)
			dgsSetVisible(tab4OBG, false)
		elseif source == tab2olustur then
			dgsSetVisible(tab1OBG, false)
			dgsSetVisible(tab2OBG, true)
			dgsSetVisible(tab3OBG, false)
			dgsSetVisible(tab4OBG, false)
		elseif source == tab3olustur then
			dgsSetVisible(tab1OBG, false)
			dgsSetVisible(tab2OBG, false)
			dgsSetVisible(tab3OBG, true)
			dgsSetVisible(tab4OBG, false)
		elseif source == tab4olustur then
			dgsSetVisible(tab1OBG, false)
			dgsSetVisible(tab2OBG, false)
			dgsSetVisible(tab3OBG, false)
			dgsSetVisible(tab4OBG, true)
		elseif source == tab1klan then
			dgsSetVisible(tab1KBG, true)
			dgsSetVisible(tab2KBG, false)
			dgsSetVisible(tab3KBG, false)
			dgsSetVisible(tab4KBG, false)
		elseif source == tab2klan then
			dgsSetVisible(tab1KBG, false)
			dgsSetVisible(tab2KBG, true)
			dgsSetVisible(tab3KBG, false)
			dgsSetVisible(tab4KBG, false)
		elseif source == tab3klan then
			dgsSetVisible(tab1KBG, false)
			dgsSetVisible(tab2KBG, false)
			dgsSetVisible(tab3KBG, true)
			dgsSetVisible(tab4KBG, false)
		elseif source == tab4klan then
			dgsSetVisible(tab1KBG, false)
			dgsSetVisible(tab2KBG, false)
			dgsSetVisible(tab3KBG, false)
			dgsSetVisible(tab4KBG, true)
		elseif source == sampiyonlukTakimlar then
			if secilen(sampiyonlukTakimlar) then
				triggerServerEvent("takımSeçtim", getLocalPlayer(), secilen(sampiyonlukTakimlar), "sampiyonluk")
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == takimlargrid then
			if secilen(takimlargrid) then
				triggerServerEvent("takımSeçtim", getLocalPlayer(), secilen(takimlargrid), "user")
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == cpgrid then
			if secilen(cpgrid) then
				triggerServerEvent("takımSeçtim", getLocalPlayer(), secilen(cpgrid), "user")
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == yetkiliTakimlar then
			if secilen(yetkiliTakimlar) then
				triggerServerEvent("takımSeçtim", getLocalPlayer(), secilen(yetkiliTakimlar), "yetkili")
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == yetkiliTakimlar2 then
			if secilen(yetkiliTakimlar2) then
				triggerServerEvent("takımSeçtim", getLocalPlayer(), secilen(yetkiliTakimlar2), "yetkili")
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == takimbilgisi1D then
			triggerServerEvent("takımİşleviDeğiştir", getLocalPlayer(), "bilgi1", tostring(dgsGetText(takimbilgisi1EB2)))
			dgsSetVisible(beklemeEkrani, true)
		elseif source == takimbilgisi2D then
			triggerServerEvent("takımİşleviDeğiştir", getLocalPlayer(), "bilgi2", dgsGetText(takimbilgisi2EB2))
			dgsSetVisible(beklemeEkrani, true)
		elseif source == renkButon then
			local renk = dgsGetText(renkEdit)
			local r, g, b = getColorFromString(renk)
			triggerServerEvent("onBuy", getLocalPlayer(), r, g, b, renk)
			dgsSetVisible(beklemeEkrani, true)
		elseif source == tTagB then
			triggerServerEvent("takımİşleviDeğiştir", getLocalPlayer(), "tag", dgsGetText(tTagE))
			dgsSetVisible(beklemeEkrani, true)
		elseif source == tIsimB then
			triggerServerEvent("takımİşleviDeğiştir", getLocalPlayer(), "isim", dgsGetText(tIsimE))
			dgsSetVisible(beklemeEkrani, true)
		elseif source == YetkiAlmapenceresiKapatL then
			dgsSetVisible(wndClanPanel, true)
			dgsSetVisible(YetkiAlmapenceresi, false)
		elseif source == klanRutbeler then
			local index = dgsGridListGetSelectedItem(klanRutbeler)
			if not (index == -1) then
				triggerServerEvent("rütbeVerisi", getLocalPlayer(), dgsGridListGetItemText(klanRutbeler, index, 1))
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == yeniRutbe then
			if dgsGridListGetRowCount(klanRutbeler) < 5 then
				local row = dgsGridListAddRow(klanRutbeler)
				dgsGridListSetItemText(klanRutbeler, row, 1, "Yeni Rütbe")
				dgsGridListSetItemColor(klanRutbeler, row, 1, 0, 255, 0)
				dgsSetText(rutbeIsmi, "Yeni Rütbe")
				dgsSetText(rutbeRengiE, "#00FF00")
				triggerServerEvent("rütbeOluştur", getLocalPlayer(), dgsGridListGetRowCount(klanRutbeler))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım rütbesinden"..aRenk.." sadece "..fRenk.."5"..aRenk.." adet oluşturulur", 0, 0, 0, true)
			end
		elseif source == rutbeKaydet then
			local row, col = dgsGridListGetSelectedItem(klanRutbeler)
			if row == -1 then
				outputChatBox(tRenkY..fRenk.." Rütbe"..aRenk.." seçmelisin", 0, 0, 0, true)
			else
				if #dgsGetText(rutbeRengiE) == 7 then
					triggerServerEvent("rütbeKaydet", getLocalPlayer(),
						row,
						dgsGetText(rutbeIsmi),
						dgsGetText(rutbeRengiE),
						dgsCheckBoxGetSelected(tBilgi1),
						dgsCheckBoxGetSelected(tBilgi2),
						dgsCheckBoxGetSelected(tIsmi),
						dgsCheckBoxGetSelected(tTagi),
						dgsCheckBoxGetSelected(tRutbeDuzen),
						dgsCheckBoxGetSelected(tOdulVer),
						dgsCheckBoxGetSelected(tDavetEt),
						dgsCheckBoxGetSelected(tAt),
						dgsCheckBoxGetSelected(tRenk),
						dgsCheckBoxGetSelected(tRutbeVerAl)
					)
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Renk kodu"..aRenk.." hatalı", 0, 0, 0, true)
				end
			end
		elseif source == rutbeSil then
			local row, col = dgsGridListGetSelectedItem(klanRutbeler)
			if row == -1 then
				outputChatBox(tRenkY..fRenk.." Rütbe"..aRenk.." seçmelisin", 0, 0, 0, true)
			else
				triggerServerEvent("rutbeSil", getLocalPlayer(), row, dgsGridListGetRowCount(klanRutbeler))
				dgsSetVisible(beklemeEkrani, true)
			end
		elseif source == rutbeAl then
			if secilen(klanUyeler) then
				triggerServerEvent("clanYetkiAl", getLocalPlayer(), secilen(klanUyeler))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == rutbeVer then
			if secilen(klanUyeler) then
				local row = dgsGridListGetSelectedItem(klanRutbeler)
				if row ~= -1 then
					triggerServerEvent("clanYetkiVer", getLocalPlayer(), secilen(klanUyeler), dgsGridListGetItemText(klanRutbeler, row, 1))
					dgsSetVisible(beklemeEkrani, true)
				else
					outputChatBox(tRenkY..fRenk.." Rütbe"..aRenk.." seçmelisin", 0, 0, 0, true)
				end
			else
				outputChatBox(tRenkY..fRenk.." Oyuncu"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == takimlariSil then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "takımlarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == takimlariSil2 then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "takımlarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == sampiyonluklariSil then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "şampiyonluklarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == sampiyonluklariSil2 then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "şampiyonluklarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == kazanmalariSil then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "kazanmalarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == kazanmalariSil2 then
			triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "kazanmalarıSil")
			dgsSetVisible(beklemeEkrani, true)
		elseif source == takimiSil then
			if secilen(yetkiliTakimlar) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "takımıSil", secilen(yetkiliTakimlar))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == takimiSil2 then
			if secilen(yetkiliTakimlar2) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "takımıSil", secilen(yetkiliTakimlar2))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == sampiyonluguSil then
			if secilen(yetkiliTakimlar) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "şampiyonluğuSil", secilen(yetkiliTakimlar))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == sampiyonluguSil2 then
			if secilen(yetkiliTakimlar2) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "şampiyonluğuSil", secilen(yetkiliTakimlar2))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == kazanmayiSil then
			if secilen(yetkiliTakimlar) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "kazanmayıSil", secilen(yetkiliTakimlar))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == kazanmayiSil2 then
			if secilen(yetkiliTakimlar2) then
				triggerServerEvent("takımlaraİşlevYap", getLocalPlayer(), "kazanmayıSil", secilen(yetkiliTakimlar2))
				dgsSetVisible(beklemeEkrani, true)
			else
				outputChatBox(tRenkY..fRenk.." Takım"..aRenk.." seçmelisin", 0, 0, 0, true)
			end
		elseif source == gecmisSil then
			triggerServerEvent("takımİşleviDeğiştir", getLocalPlayer(), "geçmişSil")
			dgsSetVisible(beklemeEkrani, true)
		end
	end
end)

function rutbeVerileri(rutbeTablo, rutbeIsim)
	dgsSetText(rutbeIsmi, rutbeIsim)
	for _, v in ipairs(rutbeTablo) do
		local r, g, b = getColorFromString(v.rutbeR)
		dgsSetText(rutbeRengiE, v.rutbeR)
		if v.rutbeB1 == tostring(true) then v.rutbeB1 = false else v.rutbeB1 = true end
		if v.rutbeB2 == tostring(true) then v.rutbeB2 = false else v.rutbeB2 = true end
		if v.rutbeIsim == tostring(true) then v.rutbeIsim = false else v.rutbeIsim = true end
		if v.rutbeTag == tostring(true) then v.rutbeTag = false else v.rutbeTag = true end
		if v.rutbeDuzen == tostring(true) then v.rutbeDuzen = false else v.rutbeDuzen = true end
		if v.rutbeOdul == tostring(true) then v.rutbeOdul = false else v.rutbeOdul = true end
		if v.rutbeDavet == tostring(true) then v.rutbeDavet = false else v.rutbeDavet = true end
		if v.rutbeAt == tostring(true) then v.rutbeAt = false else v.rutbeAt = true end
		if v.rutbeRenk == tostring(true) then v.rutbeRenk = false else v.rutbeRenk = true end
		if v.rutbeVer == tostring(true) then v.rutbeVer = false else v.rutbeVer = true end
		dgsCheckBoxSetSelected(tBilgi1, v.rutbeB1)
		dgsCheckBoxSetSelected(tBilgi2, v.rutbeB2)
		dgsCheckBoxSetSelected(tIsmi, v.rutbeIsim)
		dgsCheckBoxSetSelected(tTagi, v.rutbeTag)
		dgsCheckBoxSetSelected(tRutbeDuzen, v.rutbeDuzen)
		dgsCheckBoxSetSelected(tOdulVer, v.rutbeOdul)
		dgsCheckBoxSetSelected(tDavetEt, v.rutbeDavet)
		dgsCheckBoxSetSelected(tAt, v.rutbeAt)
		dgsCheckBoxSetSelected(tRenk, v.rutbeRenk)
		dgsCheckBoxSetSelected(tRutbeVerAl, v.rutbeVer)
		dgsSetProperty(tBilgi1, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tBilgi2, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tIsmi, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tTagi, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tRutbeDuzen, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tOdulVer, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tDavetEt, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tAt, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tRenk, "textColor", tocolor(r, g, b, 255))
		dgsSetProperty(tRutbeVerAl, "textColor", tocolor(r, g, b, 255))
	end
end
addEvent("rütbeVerileri", true)
addEventHandler("rütbeVerileri", root, rutbeVerileri)

addEventHandler("takımSıralaması", getRootElement(), 
function(clans)
	dgsGridListClearRow(cpgrid)
	dgsGridListClearRow(takimlargrid)
	dgsGridListClearRow(yetkiliTakimlar)
	dgsGridListClearRow(yetkiliTakimlar2)
	for i = 1, #clans do
		setTimer(function()
			local row1 = dgsGridListAddRow(cpgrid)
			if i == 1 then
				dgsGridListSetItemImage(cpgrid, row1, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(cpgrid, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 2 then
				dgsGridListSetItemImage(cpgrid, row1, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(cpgrid, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 3 then
				dgsGridListSetItemImage(cpgrid, row1, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(cpgrid, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			else
				dgsGridListSetItemText(cpgrid, row1, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			end
			dgsGridListSetItemText(cpgrid, row1, 2, "	"..clans[i].uyeler)
			dgsGridListSetItemText(cpgrid, row1, 3, "   "..clans[i].kazanma)
			dgsGridListSetItemText(cpgrid, row1, 4, "	 "..clans[i].sampiyonluk)
			dgsGridListSetItemText(cpgrid, row1, 5, clans[i].tarih)
			dgsGridListSetItemColor(cpgrid, row1, 1, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(cpgrid, row1, 2, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(cpgrid, row1, 3, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(cpgrid, row1, 4, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(cpgrid, row1, 5, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemData(cpgrid, row1, 1, clans[i].tag)

			local row2 = dgsGridListAddRow(takimlargrid)
			if i == 1 then
				dgsGridListSetItemImage(takimlargrid, row2, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(takimlargrid, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 2 then
				dgsGridListSetItemImage(takimlargrid, row2, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(takimlargrid, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 3 then
				dgsGridListSetItemImage(takimlargrid, row2, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(takimlargrid, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			else
				dgsGridListSetItemText(takimlargrid, row2, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			end
			dgsGridListSetItemText(takimlargrid, row2, 2, "	"..clans[i].uyeler)
			dgsGridListSetItemText(takimlargrid, row2, 3, "   "..clans[i].kazanma)
			dgsGridListSetItemText(takimlargrid, row2, 4, "	 "..clans[i].sampiyonluk)
			dgsGridListSetItemText(takimlargrid, row2, 5, clans[i].tarih)
			dgsGridListSetItemColor(takimlargrid, row2, 1, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(takimlargrid, row2, 2, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(takimlargrid, row2, 3, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(takimlargrid, row2, 4, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(takimlargrid, row2, 5, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemData(takimlargrid, row2, 1, clans[i].tag)

			local row3 = dgsGridListAddRow(yetkiliTakimlar)
			if i == 1 then
				dgsGridListSetItemImage(yetkiliTakimlar, row3, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar, row3, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 2 then
				dgsGridListSetItemImage(yetkiliTakimlar, row3, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar, row3, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 3 then
				dgsGridListSetItemImage(yetkiliTakimlar, row3, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar, row3, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			else
				dgsGridListSetItemText(yetkiliTakimlar, row3, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			end
			dgsGridListSetItemText(yetkiliTakimlar, row3, 2, " "..clans[i].kurucu)
			dgsGridListSetItemText(yetkiliTakimlar, row3, 3, "   "..clans[i].kazanma)
			dgsGridListSetItemText(yetkiliTakimlar, row3, 4, "	 "..clans[i].sampiyonluk)
			dgsGridListSetItemColor(yetkiliTakimlar, row3, 1, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar, row3, 2, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar, row3, 3, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar, row3, 4, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemData(yetkiliTakimlar, row3, 1, clans[i].tag)

			local row4 = dgsGridListAddRow(yetkiliTakimlar2)
			if i == 1 then
				dgsGridListSetItemImage(yetkiliTakimlar2, row4, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar2, row4, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 2 then
				dgsGridListSetItemImage(yetkiliTakimlar2, row4, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar2, row4, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			elseif i == 3 then
				dgsGridListSetItemImage(yetkiliTakimlar2, row4, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(yetkiliTakimlar2, row4, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			else
				dgsGridListSetItemText(yetkiliTakimlar2, row4, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name))
			end
			dgsGridListSetItemText(yetkiliTakimlar2, row4, 2, " "..clans[i].kurucu)
			dgsGridListSetItemText(yetkiliTakimlar2, row4, 3, "   "..clans[i].kazanma)
			dgsGridListSetItemText(yetkiliTakimlar2, row4, 4, "	 "..clans[i].sampiyonluk)
			dgsGridListSetItemColor(yetkiliTakimlar2, row4, 1, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar2, row4, 2, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar2, row4, 3, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(yetkiliTakimlar2, row4, 4, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemData(yetkiliTakimlar2, row4, 1, clans[i].tag)
		end, 200, 1)
	end
end)

addEventHandler("sampiyonlukLigi", root,
function(clans)
	dgsGridListClearRow(sampiyonlukTakimlar)
	dgsGridListClearRow(sampiyonlukTakimlar2)
	for i = 1, #clans do
		setTimer(function()
			local row1 = dgsGridListAddRow(sampiyonlukTakimlar)
			local row2 = dgsGridListAddRow(sampiyonlukTakimlar2)
			dgsGridListSetItemData(sampiyonlukTakimlar, row1, 1, clans[i].tag)
			dgsGridListSetItemData(sampiyonlukTakimlar2, row2, 1, clans[i].tag)
			dgsGridListSetItemColor(sampiyonlukTakimlar, row1, 1, clans[i].r, clans[i].g, clans[i].b)
			dgsGridListSetItemColor(sampiyonlukTakimlar2, row2, 1, clans[i].r, clans[i].g, clans[i].b)
			if i == 1 then
				dgsGridListSetItemImage(sampiyonlukTakimlar, row1, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemImage(sampiyonlukTakimlar2, row2, 1, dxCreateTexture("Parcalar/1.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(sampiyonlukTakimlar, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
				dgsGridListSetItemText(sampiyonlukTakimlar2, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
			elseif i == 2 then
				dgsGridListSetItemImage(sampiyonlukTakimlar, row1, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemImage(sampiyonlukTakimlar2, row2, 1, dxCreateTexture("Parcalar/2.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(sampiyonlukTakimlar, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
				dgsGridListSetItemText(sampiyonlukTakimlar2, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
			elseif i == 3 then
				dgsGridListSetItemImage(sampiyonlukTakimlar, row1, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemImage(sampiyonlukTakimlar2, row2, 1, dxCreateTexture("Parcalar/3.png"), _, 0, 0, 50, 15)
				dgsGridListSetItemText(sampiyonlukTakimlar, row1, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
				dgsGridListSetItemText(sampiyonlukTakimlar2, row2, 1, "              "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
			else
				dgsGridListSetItemText(sampiyonlukTakimlar, row1, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
				dgsGridListSetItemText(sampiyonlukTakimlar2, row2, 1, i.."-) "..removeColorCoding(clans[i].tag).." "..removeColorCoding(clans[i].name).." ("..clans[i].sampiyonluk..")")
			end
		end, 200, 1)
	end
end)

function removeColorCoding(name)
	return type(name)=="string" and string.gsub(name, "#%x%x%x%x%x%x", "") or name
end

function clanIslem()
	if getElementData(getLocalPlayer(), "clanpanel") == "true" then
		cPanelCikis("left")
		coVazgec("left")
		dgsSetVisible(wndDavetGeldi, false)
		dgsSetVisible(takimGecmisP, false)
		dgsSetVisible(rutbeDuzenleP, false)
		dgsSetVisible(ClandanAtmaW, false)
		dgsSetVisible(ClanDevretW, false)
		dgsSetVisible(clanKapaltTest, false)
		dgsSetVisible(YetkiAlmapenceresi, false)
	else
		triggerServerEvent("clanIslem", getLocalPlayer())
		dgsSetVisible(beklemeEkrani, true)
	end
end
addEvent("clanIslem", true)
addEventHandler("clanIslem", getRootElement(), clanIslem)

function adssda(ele)
	if dgsGetVisible(wndClanOlustur) == true then
		openPicker("olustur", dgsGetText(txtCORenk), "Takım Renk Kodu")
		dgsSetVisible(wndClanOlustur, false)
	end
	if dgsGetVisible(wndClanPanel) == true then
		openPicker("klan", dgsGetText(renkEdit), "Takım Renk Kodu")
		dgsSetVisible(wndClanPanel, false)
	end
	if dgsGetVisible(YetkiAlmapenceresi) == true then
		openPicker("rutbe", dgsGetText(rutbeRengiE), "Rütbe Renk Kodu")
		dgsSetVisible(YetkiAlmapenceresi, false)
	end
end

addEvent("onColorPickerOK", true )
addEventHandler("onColorPickerOK", root, 
function(element, hex, r, g, b)
	if element == "olustur" then
		dgsSetText(txtCORenk, hex)
		dgsSetVisible(wndClanOlustur, true)
	elseif element == "klan" then
		dgsSetVisible(wndClanPanel, true)
		dgsSetText(renkEdit, hex)
	elseif element == "rutbe" then
		dgsSetVisible(YetkiAlmapenceresi, true)
		dgsSetText(rutbeRengiE, hex)
	end
	showCursor(true)
end)

addEvent("onColorPickerNO", true)
addEventHandler("onColorPickerNO", root, 
function(element)
	if element == "olustur" then
		dgsSetVisible(wndClanOlustur, true)
	elseif element == "klan" then
		dgsSetVisible(wndClanPanel, true)
	elseif element == "rutbe" then
		dgsSetVisible(YetkiAlmapenceresi, true)
	end
	showCursor(true)
end)
