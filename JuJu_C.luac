addEvent("sunucununİşlevi", true)
addEventHandler("sunucununİşlevi", root, sunucununIslevi)

function createClanOlustur()
	beklemeEkrani = dgsCreateImage(0, 0, screenx, screeny, "Parcalar/resim.png", false, _, tocolor(0, 0, 0, 0))
	dgsSetVisible(beklemeEkrani, false)
	beklemeEkraniL = dgsCreateLabel(0, 0, screenx, screeny, "Lütfen Bekleyiniz...", false, beklemeEkrani)
	dgsLabelSetColor(beklemeEkraniL, 255, 0, 0)
	dgsSetProperty(beklemeEkraniL, "textSize", {5, 5})
	dgsLabelSetHorizontalAlign(beklemeEkraniL, "center", false)
	dgsLabelSetVerticalAlign(beklemeEkraniL, "center")
	wndClanOlustur = dgsCreateWindow(x, y, width, height, "Takım Paneli", false)
	dgsWindowSetMovable(wndClanOlustur, false)
	dgsWindowSetSizable(wndClanOlustur, false)
	dgsSetVisible(wndClanOlustur, false)
	wndClanOlusturKapat = dgsCreateImage(width-40, -25, 40, 25, "Parcalar/resim.png", false, wndClanOlustur, tocolor(200, 50, 50, 255))
