addEvent("takımSıralaması", true)
addEvent("sunucuÜyeleri", true)
addEvent("ekranıKapat", true)
addEvent("sampiyonlukLigi", true)
addEventHandler("onClientResourceStart", getResourceRootElement(getThisResource()),
function()
	createClanOlustur()
	createDavetGeldi()
	clanPanelOlustur()
	closeClanTest()
	ClandanAtma()
	YetkiAlma()
	ClanDevret()
	triggerServerEvent("sunucununİşlevi", getLocalPlayer(), dgsGetFont(takimiSil2))
end)

local resimTexture = dxCreateTexture(1, 1)
local resimPixels = dxGetTexturePixels(resimTexture)
dxSetPixelColor(resimPixels, 0, 0, 255, 255, 255, 255)
dxSetTexturePixels(resimTexture, resimPixels)
if fileExists("Parcalar/resim.png") then
	fileDelete("Parcalar/resim.png")
end
local resimTuru = dxConvertPixels(dxGetTexturePixels(resimTexture), "png")
local resmim = fileCreate("Parcalar/resim.png")
fileWrite(resmim, resimTuru)
fileClose(resmim)
loadstring(exports.dgs:dgsImportFunction())()
local screenx, screeny = guiGetScreenSize()
local width, height = 655, 550
local x, y = (screenx/2-width/2), (screeny/2-height/2)
local tRenkY, fRenk, aRenk

function sunucununIslevi(arg1, arg2, arg3, arg4, arg5, arg6, arg7, arg8, arg9, arg10, arg11, arg12, arg13, arg14)
	dgsSetText(takimOdulu, "Takımın Şampiyonluk Ödülü: "..arg1)
	bindKey(arg2, "down", clanIslem)
	local r3, g3, b3 = getColorFromString(arg3)
	local r4, g4, b4 = getColorFromString(arg4)
	local r5, g5, b5 = getColorFromString(arg5)
	local r6, g6, b6 = getColorFromString(arg6)
	local r7, g7, b7 = getColorFromString(arg7)
	local r8, g8, b8 = getColorFromString(arg8)
	local r9, g9, b9 = getColorFromString(arg9)
	local r10, g10, b10 = getColorFromString(arg10)
	local r11, g11, b11 = getColorFromString(arg11)
	tRenkY, fRenk, aRenk = arg12, arg13, arg14
	dgsSetProperty(tab1klan, "color", {tocolor(r3, g3, b3, 255), tocolor(r4, g4, b4, 255), tocolor(r5, g5, b5, 255)})
	dgsSetProperty(tab2klan, "color", {tocolor(r3, g3, b3, 255), tocolor(r4, g4, b4, 255), tocolor(r5, g5, b5, 255)})
